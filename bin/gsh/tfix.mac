	MACRO	_subp	&elem,&work	gbla	&totlen	lclc	&p	lclc	&len&p	setc	&elem&len	amid	&p,2,1	aif	"&len"=":",.c&len	amid	&p,1,2&p	amid	&p,4,l:&p-3	ago	.d.c&len	amid	&p,1,1&p	amid	&p,3,l:&p-2.d&p	equ	&totlen+3+&work&totlen	seta	&totlen+&len	mend	MACRO&lab	subroutine &parms,&work	gbla	&totlen	gbla	&worklen	lcla	&nn&lab	anop	aif	c:&work,.a	lclc	&work&work	setc	0.a&worklen	seta	&work&totlen	seta	0	aif	c:&parms=0,.e&nn	seta	c:&parms	_subp	&parms(&nn),&work	aif	&nn<2,.e&nn	seta	&nn-1	_subp	&parms(&nn),&work.e	tsc	sec	sbc	#&work	tcs	inc	a	phd	tcd	phb	phk	plb	mend