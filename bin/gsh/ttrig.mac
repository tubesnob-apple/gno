	MACRO	_proc_p	&elem,&work	gbla	&totlen	lclc	&p	lclc	&len	mnote	'A: before p setc',0&p	setc	&elem	mnote	'B: after p setc',0&len	amid	&p,2,1	mnote	'C: after len amid',0	aif	"&len"=":",.c	mnote	'D: not colon branch',0&len	amid	&p,1,2&p	amid	&p,4,l:&p-3	ago	.d.c	mnote	'E: colon branch',0&len	amid	&p,1,1&p	amid	&p,3,l:&p-2.d	mnote	'F: at .d',0&p	equ	&totlen+3+&work	mnote	'G: after equ',0&totlen	seta	&totlen+&len	mnote	'H: done',0	mend	MACRO&lab	subroutine &parms,&work	gbla	&totlen	gbla	&worklen	lcla	&nn&lab	anop	aif	c:&work,.a	lclc	&work&work	setc	0.a&worklen	seta	&work&totlen	seta	0	aif	c:&parms=0,.e&nn	seta	c:&parms	_proc_p	&parms(&nn),&work.e	tsc	mend