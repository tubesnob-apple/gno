#
# goldengate/build/lsaneglue.mk
#
# Build lsaneglue — SANE glue code for GNO.
#
# Usage (run from REPO_ROOT):
#   make -f goldengate/build/lsaneglue.mk
#   make -f goldengate/build/lsaneglue.mk clean
#
# Output: $(LIB_OUT)
# Source: lib/lsaneglue/saneglue.asm + findfpcp.asm
#
# Notes:
#   - .mac files are generated by macgen before assembly
#   - saneglue.asm uses 'copy E16.SANE' — E16.SANE symlinked in SRC_DIR
#   - Assembly output gets $B0 type by default; patched to $B1 for makelib

REPO_ROOT ?= $(shell cd "$(dir $(lastword $(MAKEFILE_LIST)))/../.." && pwd)
GG_ROOT   ?= $(or $(GOLDEN_GATE),$(ORCA_ROOT),$(HOME)/Library/GoldenGate)
LIB_OUT   ?= $(abspath $(REPO_ROOT)/gno_obj/lib/lsaneglue)

SRC_DIR   := $(REPO_ROOT)/lib/lsaneglue
AINCLUDE  := $(GG_ROOT)/Libraries/AINClude
ORCAINC   := $(GG_ROOT)/Libraries/ORCAInclude

AS        := iix assemble
MACGEN    := iix macgen
MAKELIB   := iix makelib
SET_FINDERINFO := python3 $(REPO_ROOT)/goldengate/tools/set-finder-info.py

ASFLAGS   := +T
PRODOS_OBJ_FINDERINFO := 70 B1 00 00 70 64 6F 73 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00

.PHONY: all
all: $(LIB_OUT)

$(LIB_OUT): $(SRC_DIR)/saneglue.A $(SRC_DIR)/findfpcp.A | $(dir $(LIB_OUT))
	rm -f $(LIB_OUT)
	$(MAKELIB) $(LIB_OUT) +$(SRC_DIR)/saneglue.A
	$(MAKELIB) $(LIB_OUT) +$(SRC_DIR)/findfpcp.A

# Generate saneglue.mac from macros
$(SRC_DIR)/saneglue.mac: $(SRC_DIR)/saneglue.asm $(SRC_DIR)/saneglue.macro
	cd $(SRC_DIR) && $(MACGEN) -p saneglue.asm saneglue.mac saneglue.macro \
	  $(AINCLUDE)/M16.SANE $(ORCAINC)/m16.ORCA

# Generate findfpcp.mac from macros
$(SRC_DIR)/findfpcp.mac: $(SRC_DIR)/findfpcp.asm
	cd $(SRC_DIR) && $(MACGEN) -p findfpcp.asm findfpcp.mac \
	  $(ORCAINC)/m16.ORCA

# Ensure E16.SANE symlink exists in source dir (for 'copy E16.SANE' directive)
$(SRC_DIR)/E16.SANE:
	ln -sf $(AINCLUDE)/E16.SANE $@

$(SRC_DIR)/saneglue.A: $(SRC_DIR)/saneglue.asm $(SRC_DIR)/saneglue.mac $(SRC_DIR)/E16.SANE
	cd $(SRC_DIR) && $(AS) $(ASFLAGS) saneglue.asm
	$(SET_FINDERINFO) $@ "$(PRODOS_OBJ_FINDERINFO)"

$(SRC_DIR)/findfpcp.A: $(SRC_DIR)/findfpcp.asm $(SRC_DIR)/findfpcp.mac
	cd $(SRC_DIR) && $(AS) $(ASFLAGS) findfpcp.asm
	$(SET_FINDERINFO) $@ "$(PRODOS_OBJ_FINDERINFO)"

$(dir $(LIB_OUT)):
	mkdir -p $@

.PHONY: clean
clean:
	rm -f $(SRC_DIR)/saneglue.A $(SRC_DIR)/saneglue.ROOT
	rm -f $(SRC_DIR)/findfpcp.A $(SRC_DIR)/findfpcp.ROOT
	rm -f $(SRC_DIR)/saneglue.mac $(SRC_DIR)/findfpcp.mac
	rm -f $(LIB_OUT)
