;;  The following variables control the debug aids.  If DEBUG and DEBUGK are;  both set to false, no debug code is generated.;;  If DEBUGK is true, the keep routine that normally writes to an object module;  is replaced by a subroutine which immediately echoes the bytes to the CRT.;;  If DEBUG is true, the subroutine STRCE is included in the code, and each of;  the DEBUG macros which appear at the top of subroutines generates a call;  to that routine, followed by a 10 character string containing the name;  of the subroutine.  This alone helps in finding suroutines for debugging.;  If TRACE contains a 1 at the time of the call to STRCE, that subroutine will;  print the name of the subroutine on the CRT.;true	gequ	1	boolean constantsfalse	gequ	0apw	gequ	false	APW or ORCA/M?debug	gequ	false	enable/disable trace codedebugk	gequ	false	FKEEP debug flag;;  Global constants;maxName	gequ	2048	max length of a file namenameBuff gequ	4	length of the name buffer;;  Direct Page Equates;r0	gequ	$00	General Use Registersr1	gequ	$01r2	gequ	$02r3	gequ	$03r4	gequ	$04r5	gequ	$05r6	gequ	$06r7	gequ	$07r8	gequ	$08r9	gequ	$09r10	gequ	$0Ar11	gequ	$0Br12	gequ	$0Cr13	gequ	$0Dr14	gequ	$0Er15	gequ	$0Fm1l	gequ	$10	Integer Math Registersm1h	gequ	$11m2l	gequ	$12m2h	gequ	$13m3l	gequ	$18m3h	gequ	$19sign	gequ	$1C	Integer Math Signretad	gequ	$1E	SRITE return addresschrad	gequ	$20	SRITE character addressmsp	gequ	$22	stack ptr for macro tablefr1	gequ	$26	floating point registersgsp	gequ	$30	stack ptr for global symbol tablelsp	gequ	$34	stack ptr for local symbol tableasp	gequ	$38	stack ptr for AINPUT tablecsp	gequ	$3C	current sumbolic parm stack endap	gequ	$40	assembly text pointerlockp	gequ	$44	work pointer for LOCKtempzp	gequ	$48	temp work spacekeepHandle gequ $68	handle of teh keep file bufferkeepHandle2 gequ $6C	temp keephandlekp1	gequ	$70	temp pointers for keep file usekp2	gequ	$74!		$78	next available space!		$A0-$CF      this space is reserved for use in file.asmwr0	gequ	$E0	working registerswr1	gequ	$E1wr2	gequ	$E2wr3	gequ	$E3wr4	gequ	$E4mr0	gequ	$E8	macro parameter passing registersmr1	gequ	$E9mr2	gequ	$EAmr3	gequ	$EB